{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_layout": {
    "description": "Project-wide settings for Case6 portfolio. Custom keys prefixed with _ are documentation only and ignored by Claude Code at runtime.",
    "structure": {
      "root_map": "CLAUDE.md",
      "memory": ".claude/memory/",
      "skills": ".claude/skills/",
      "plans": ".claude/plans/",
      "policies": [
        ".claude/automation-policy.md"
      ],
      "team_scopes": {
        "frontend": "frontend/",
        "design": "design/",
        "cicd": "cicd/"
      }
    }
  },
  "worktree": {
    "_note": "Optimization for `claude --worktree` runs in this monorepo. Symlinked dirs avoid duplicating heavy artifacts; sparsePaths limits checkout to the union of all team scopes plus shared root files.",
    "symlinkDirectories": [
      "node_modules",
      "frontend/node_modules",
      "frontend/dist",
      ".vite"
    ],
    "sparsePaths": [
      "frontend/",
      "design/",
      "cicd/",
      ".claude/",
      ".github/",
      "CLAUDE.md",
      "package.json",
      "package-lock.json",
      "vite.config.ts",
      "tsconfig.json"
    ]
  },
  "permissions": {
    "additionalDirectories": [],
    "allow": [
      "Bash(ls:*)",
      "Bash(pwd)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(file:*)",
      "Bash(wc:*)",
      "Bash(tree:*)",
      "Bash(echo:*)",
      "Bash(which:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git show:*)",
      "Bash(git ls-files:*)",
      "Bash(git fetch:*)",
      "Bash(git pull:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git checkout:*)",
      "Bash(git switch:*)",
      "Bash(git stash:*)",
      "Bash(git merge:*)",
      "Bash(git restore:*)",
      "Bash(npm install)",
      "Bash(npm ci)",
      "Bash(npm run build)",
      "Bash(npm run dev)",
      "Bash(npm run preview)",
      "Bash(npm run test:*)",
      "Bash(npm test:*)",
      "Bash(npx vite:*)",
      "Bash(npx vitest:*)",
      "Bash(npx tsc:*)",
      "Bash(node:*)",
      "Bash(mkdir:*)",
      "Bash(touch:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh issue view:*)",
      "Bash(gh issue list:*)",
      "Bash(gh api:*)"
    ],
    "ask": [
      "Bash(git push:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr merge:*)",
      "Bash(gh pr close:*)",
      "Bash(gh release:*)",
      "Bash(rm -r:*)",
      "Bash(rm -rf:*)",
      "Bash(npm uninstall:*)",
      "Bash(npm install --save-dev:*)",
      "Bash(npm install -D:*)",
      "Write(.github/workflows/**)",
      "Edit(.github/workflows/**)",
      "Edit(vite.config.ts)",
      "Edit(package.json)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~/*)",
      "Bash(rm -rf ../*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push --force-with-lease:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -fd:*)",
      "Bash(git clean -fdx:*)",
      "Bash(git branch -D:*)",
      "Bash(git checkout --:*)",
      "Bash(npm publish:*)",
      "Bash(yarn publish:*)",
      "Bash(pnpm publish:*)",
      "Bash(curl * | sh)",
      "Bash(curl * | bash)",
      "Bash(wget * | sh)",
      "Bash(wget * | bash)",
      "Bash(sudo:*)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/credentials.json)",
      "Read(**/secrets.json)",
      "Read(**/*.pem)",
      "Read(**/id_rsa)",
      "Read(**/id_ed25519)",
      "Write(.env)",
      "Write(.env.*)",
      "Edit(.env)",
      "Edit(.env.*)"
    ]
  },
  "env": {
    "BASH_DEFAULT_TIMEOUT_MS": "300000",
    "BASH_MAX_TIMEOUT_MS": "600000",
    "CASE6_MEMORY_DIR": ".claude/memory",
    "CASE6_SKILLS_DIR": ".claude/skills",
    "CASE6_PLANS_DIR": ".claude/plans",
    "CASE6_AUTOMATION_POLICY": ".claude/automation-policy.md",
    "CASE6_TEAM_FRONTEND_DIR": "frontend",
    "CASE6_TEAM_DESIGN_DIR": "design",
    "CASE6_TEAM_CICD_DIR": "cicd"
  },
  "includeCoAuthoredBy": true,
  "cleanupPeriodDays": 30
}
